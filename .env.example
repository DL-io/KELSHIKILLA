# Core app
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/polymarket
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Intelligence
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
X_BEARER_TOKEN=
NEWS_API_KEY=
NEWS_LOOKBACK_HOURS=24

# Kalshi — RSA-PSS API key auth (replaces email/password)
KALSHI_API_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
# Provide ONE of the following two for the private key:
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_EXECUTION_MODE=paper
KALSHI_KILLSWITCH_ARMED=false
# Micro-bankroll risk limits (defaults safe for ~$20 bankroll)
KALSHI_MAX_POSITION_USD=2
KALSHI_ABSOLUTE_MAX_POSITION_USD=3
KALSHI_MAX_TOTAL_EXPOSURE_USD=8
KALSHI_MAX_DAILY_LOSS_USD=3
KALSHI_MIN_BANKROLL_RESERVE_USD=10
KALSHI_ORDER_TTL_MS=15000
KALSHI_POST_ONLY=true
KALSHI_ALLOWED_MAX_DAYS_TO_RESOLUTION=2
KALSHI_PREFERRED_HOURS_TO_RESOLUTION_MIN=6
KALSHI_PREFERRED_HOURS_TO_RESOLUTION_MAX=48
# Legacy email/password (no longer used — kept for reference)
KALSHI_EMAIL=
KALSHI_PASSWORD=
DEEP_EDGE_MIN_SCORE=0.7
DEEP_EDGE_MIN_CONFIDENCE=0.8
MAX_BASKET_LEGS=10
CATALYST_TIMEOUT_MULTIPLIER=1.5

# Live trading global gate
LIVE_TRADING_ENABLED=false

# Polymarket CLOB v2
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=0
POLYGON_RPC_URL=
POLYMARKET_DEFAULT_TICK_SIZE=0.01
POLYMARKET_WS_URL=

# Polymarket L2 credentials.
# Leave blank before first derive. The adapter can derive via createOrDeriveApiKey()
# when POLYMARKET_PRIVATE_KEY and POLYMARKET_CREDENTIAL_CACHE_KEY are set.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CREDENTIAL_CACHE_PATH=.polymarket-l2-credentials.enc
POLYMARKET_CREDENTIAL_CACHE_KEY=

# Live kill switch. Keep off until wallet, allowances, and dry run are complete.
KILLSWITCH_ARMED=false
KILLSWITCH_NOTIONAL_CAP_USD=500
KILLSWITCH_ORDERS_PER_MIN=10
KILLSWITCH_PER_MARKET_CAP_USD=100
KILLSWITCH_MAX_SPREAD_BPS=500
