# ═══════════════════════════════════════════════════════════════════════════════
# KELSHIKILLA — Autonomous Market Trading Infrastructure
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── CORE INFRASTRUCTURE ────────────────────────────────────────────────────────

# Application identifier
VITE_APP_ID=kelshikilla

# Node environment (development | production)
NODE_ENV=production

# Session/JWT signing secret — REQUIRED FOR PRODUCTION
JWT_SECRET=your-256-bit-random-secret-here-use-openssl-rand

# ─── DATABASE & PERSISTENCE ────────────────────────────────────────────────────

# MySQL connection — REQUIRED for operational state
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/polymarket_bot

# Redis connection — REQUIRED for async workers, queue jobs, and caching
# Format: redis://[:password]@host:port[?tls=true]
REDIS_URL=redis://localhost:6379

# ─── POLYMARKET CLOB V2 (PRIMARY EXCHANGE) ─────────────────────────────────────

# Live trading private key (curve25519) — REQUIRED FOR LIVE EXECUTION
POLYMARKET_PRIVATE_KEY=

# Funder/signer address — REQUIRED FOR LIVE EXECUTION
POLYMARKET_FUNDER_ADDRESS=

# CLOB API endpoint (production)
POLYMARKET_HOST=https://clob.polymarket.com

# Polygon chain ID (137 = mainnet)
POLYMARKET_CHAIN_ID=137

# Polygon RPC endpoint — REQUIRED FOR LIVE EXECUTION
POLYGON_RPC_URL=

# CLOB signature type (0 = EOA signature)
POLYMARKET_SIGNATURE_TYPE=0

# L2 API credentials (optional if using credential cache + cache key)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Credential cache encryption key — REQUIRED IF using credential caching
POLYMARKET_CREDENTIAL_CACHE_KEY=

# Credential cache file path
POLYMARKET_CREDENTIAL_CACHE_PATH=.polymarket-l2-credentials.enc

# User channel WebSocket URL (optional, for real-time fill updates)
POLYMARKET_WS_URL=

# Default tick size for CLOB orders
POLYMARKET_DEFAULT_TICK_SIZE=0.01

# ─── POLYMARKET KILLSWITCH (FAIL-CLOSED EXECUTION GUARD) ──────────────────────

# MUST be explicitly set to 'true' before ANY live order submission
KILLSWITCH_ARMED=false

# Per-order notional cap (USD)
KILLSWITCH_NOTIONAL_CAP_USD=100

# Orders per minute rate limit
KILLSWITCH_ORDERS_PER_MIN=6

# Per-market notional cap (USD)
KILLSWITCH_PER_MARKET_CAP_USD=100

# Maximum spread basis points (500 bps = 5%)
KILLSWITCH_MAX_SPREAD_BPS=500

# ─── KALSHI (SECONDARY EXCHANGE) ────────────────────────────────────────────────

# API authentication — REQUIRED IF using Kalshi
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_PATH=

# Kalshi API base URL
KALSHI_API_BASE_URL=https://external-api.kalshi.com/trade-api/v2

# Execution mode (paper | live)
KALSHI_EXECUTION_MODE=paper

# Killswitch for Kalshi
KALSHI_KILLSWITCH_ARMED=false

# Micro-bankroll risk limits (Kalshi: conservative $20–$100 bankroll)
KALSHI_MAX_POSITION_USD=2
KALSHI_ABSOLUTE_MAX_POSITION_USD=3
KALSHI_MAX_TOTAL_EXPOSURE_USD=8
KALSHI_MAX_DAILY_LOSS_USD=3
KALSHI_MIN_BANKROLL_RESERVE_USD=10
KALSHI_ORDER_TTL_MS=15000
KALSHI_POST_ONLY=true
KALSHI_ALLOWED_MAX_DAYS_TO_RESOLUTION=2
KALSHI_PREFERRED_HOURS_TO_RESOLUTION_MIN=6
KALSHI_PREFERRED_HOURS_TO_RESOLUTION_MAX=48

# ─── GENERAL TRADING RISK LIMITS ───────────────────────────────────────────────

# Live trading enable switch
LIVE_TRADING_ENABLED=false

# Maximum single position size (USD)
MAX_POSITION_USD=100

# Maximum portfolio drawdown (%)
MAX_DRAWDOWN_PCT=15

# Order time-to-live (milliseconds)
ORDER_TTL_MS=300000

# Polling interval (milliseconds)
POLL_INTERVAL_MS=15000

# ─── DEEP EDGE GATE (ANOMALY DETECTION & MEMORY) ────────────────────────────────

# Minimum anomaly score (0–1) to proceed with trade
DEEP_EDGE_MIN_SCORE=0.7

# Minimum deep reasoner confidence (0–1)
DEEP_EDGE_MIN_CONFIDENCE=0.8

# Maximum legs in synthetic arbitrage basket
MAX_BASKET_LEGS=10

# Catalyst timeout multiplier
CATALYST_TIMEOUT_MULTIPLIER=1.5

# ─── LLM INTELLIGENCE ENGINE ───────────────────────────────────────────────────

# LLM provider strategy: local-only | cloud-only | hybrid
LLM_PROVIDER_STRATEGY=hybrid

# Cloud providers (set at least one for production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GROK_API_KEY=
GROK_MODEL=grok-3

# Local Ollama (fallback if cloud unavailable)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_API_KEY=

# Named model roles for multi-model ensemble
LLM_PRIMARY_MODEL=
LLM_REASONER_MODEL=
LLM_EXTRACTOR_MODEL=
LLM_ENSEMBLE_MODEL=

# ─── DATA SOURCES ──────────────────────────────────────────────────────────────

# News API integration
NEWS_API_KEY=
NEWS_LOOKBACK_HOURS=24

# Twitter/X API integration
X_BEARER_TOKEN=

# ─── OWNER & OAUTH ─────────────────────────────────────────────────────────────

# Owner's OpenID (admin user)
OWNER_OPEN_ID=

# OAuth server base URL (optional)
OAUTH_SERVER_URL=

# ─── PORT & SERVER ────────────────────────────────────────────────────────────

# HTTP server port
PORT=3000

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION READINESS CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# Before deploying to production:
#
# Infrastructure:
#   ☐ DATABASE_URL set and MySQL running with 9.2+
#   ☐ REDIS_URL set and Redis running with 7.0+
#   ☐ JWT_SECRET is cryptographically strong (openssl rand -hex 32)
#
# Exchange Credentials:
#   ☐ POLYMARKET_PRIVATE_KEY configured
#   ☐ POLYMARKET_FUNDER_ADDRESS configured
#   ☐ POLYGON_RPC_URL points to working endpoint (Alchemy, Infura, etc.)
#   ☐ POLYMARKET_CREDENTIAL_CACHE_KEY set and backed up securely
#   ☐ KILLSWITCH_ARMED=true explicitly confirmed (no typos)
#
# Intelligence:
#   ☐ At least one LLM provider key set (OpenAI OR Anthropic OR Groq OR local Ollama)
#   ☐ NEWS_API_KEY and X_BEARER_TOKEN configured for data ingestion
#
# Risk Limits:
#   ☐ MAX_POSITION_USD and MAX_DRAWDOWN_PCT calibrated for your bankroll
#   ☐ KILLSWITCH_NOTIONAL_CAP_USD, ORDERS_PER_MIN, PER_MARKET_CAP set conservatively
#   ☐ Kalshi limits reviewed (defaults safe for micro-bankroll)
#
# Testing & Validation:
#   ☐ All tests passing: `pnpm test`
#   ☐ TypeCheck clean: `pnpm check`
#   ☐ Build successful: `pnpm build`
#   ☐ Lint clean: `pnpm lint`
#   ☐ Startup clean: `pnpm start` runs without errors
#   ☐ 72h+ clean paper trading log review
#   ☐ Execution audit trail verified
#   ☐ Recovery and reconciliation tested
#
# Final Gate:
#   ☐ LIVE_TRADING_ENABLED=true ONLY after all above completed
#   ☐ Operator trained on dashboard and emergency procedures
#   ☐ Killswitch procedures documented and tested
#
# ═══════════════════════════════════════════════════════════════════════════════
